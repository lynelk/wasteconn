# WasteConn environment template.
# Copy to .env.local and fill in values:  cp .env.example .env.local
# Only the VITE_* vars below are read by the frontend build/runtime.
# (Vite only exposes variables prefixed with VITE_ to the client.)

# ── Base44 app connection (required) ─────────────────────────────────────────
# The Base44 application this frontend talks to.
VITE_BASE44_APP_ID=
# Functions version/tag to call (leave blank for the default/published version).
VITE_BASE44_FUNCTIONS_VERSION=
# Base URL of the Base44 app/API. Leave blank to use the SDK default.
VITE_BASE44_APP_BASE_URL=

# ── Build (optional) ─────────────────────────────────────────────────────────
# Public base path for the build (defaults to "/").
VITE_BASE=/
# Use legacy SDK import shims if needed (build-time).
BASE44_LEGACY_SDK_IMPORTS=false

# ── Observability (optional) ─────────────────────────────────────────────────
# Uptrace OTLP/HTTP DSN. When unset, monitoring is a no-op.
VITE_UPTRACE_DSN=
# Release identifier attached to telemetry/error reports (e.g. git sha or tag).
VITE_APP_RELEASE=

# ─────────────────────────────────────────────────────────────────────────────
# Base44 FUNCTION SECRETS — NOT read from this file.
# These are configured in the Base44 backend environment (Deno.env), never in
# the client bundle. Listed here so deployers know what to provision:
#
#   SENSOR_WEBHOOK_KEY        Shared bearer token for the smart-bin ingestion webhook
#   PAYMENT_WEBHOOK_SECRET    Verifies inbound payment webhooks
#   DEFAULT_TENANT_ID         Fallback tenant for unauthenticated public reports
#   APP_BASE_URL              App base URL used by server functions (links, callbacks)
#   CITOCONNECT_API_URL / CITOCONNECT_API_KEY   SMS / messaging gateway
#   YO_API_URL / YO_USERNAME / YO_PASSWORD       Yo! mobile-money payments
#   WIALON_API_URL / WIALON_API_TOKEN            Fleet telematics sync
#   QBO_CLIENT_ID / QBO_CLIENT_SECRET / QBO_REALM_ID / QBO_REFRESH_TOKEN   QuickBooks
# ─────────────────────────────────────────────────────────────────────────────
